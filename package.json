{
  "name": "kridaz-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "Kridaz Monorepo",
  "packageManager": "pnpm@10.28.0",
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "dev:server": "cd server && npm run dev",
    "dev:user": "cd client/user && npm run dev",
    "install:all": "pnpm install",
    "test:all": "turbo test",
    "lint": "turbo lint",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.34.1",
    "prettier": "^3.2.5",
    "turbo": "^2.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "@prisma/engines",
      "@sentry-internal/node-cpu-profiler",
      "argon2",
      "esbuild",
      "ffmpeg-static",
      "msgpackr-extract",
      "prisma",
      "sharp"
    ]
  }
}
