{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^lint"]
    }
  },
  "globalEnv": [
    "VITE_API_URL",
    "VITE_USER_URL",
    "VITE_GOOGLE_CLIENT_ID",
    "VITE_RAZORPAY_KEY_ID",
    "VITE_REELS_CDN_URL",
    "VITE_TURNSTILE_SITE_KEY"
  ]
}
