OWNER_URL=          # Owner portal URL — used in email links sent to venue owners
USER_URL=           # User portal URL — used in email links sent to users

MONGO_URI=          # MongoDB connection string

JWT_SECRET=         # Secret for signing user/owner JWT auth tokens

EMAIL=              # Gmail address used to send transactional emails
PASSWORD=           # App password (Google: Account → Security → App Passwords)

PORT=6001

# Cloudinary — media uploads (profile pics, turf images, documents)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Razorpay — payment gateway
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# CORS — comma-separated list of allowed frontend origins
CLIENT_URLS=http://localhost:5174,https://kridaz.vercel.app

# Timezone for booking slot calculations (IANA name)
TIMEZONE=Asia/Kolkata

# Google OAuth — user login + YouTube integration
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# App base URL (must match what is registered in Google Cloud Console)
APP_BASE_URL=http://localhost:6001
YOUTUBE_REDIRECT_URI=http://localhost:6001/api/youtube/oauth/callback

# Railway Redis — required for: rate limiting, BullMQ jobs, socket presence
REDIS_URL=
REDIS_INTERNAL_URL=  # Use this inside Railway's private network for lower latency

# Live Broadcast — OBS overlay JWT signing
# Hard-fail: server rejects overlay connections if this is missing
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
OVERLAY_TOKEN_SECRET=

# Facebook OAuth — streaming / social login
# Get from: https://developers.facebook.com → Your App → Settings → Basic
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_REDIRECT_URI=http://localhost:6001/api/facebook/oauth/callback

# MSG91 — WhatsApp OTP & push notifications
# Get from: https://control.msg91.com → API → Auth Key
MSG91_AUTH_KEY=
MSG91_WHATSAPP_OTP_TEMPLATE=    # Template ID for OTP messages
MSG91_WHATSAPP_NOTIF_TEMPLATE=  # Template ID for booking/event notifications
MSG91_WHATSAPP_SENDER=          # Registered WhatsApp sender ID

# AI Services
OPENAI_API_KEY=  # Required for AI match commentary generation

# Cloudflare Turnstile — bot protection
TURNSTILE_SECRET_KEY=

# Cloudflare R2 — video/asset storage
R2_BUCKET_NAME=
R2_PUBLIC_DEV_URL=
R2_CATALOG_URI=
R2_WAREHOUSE_NAME=

# Runtime environment — set to 'production' on deploy host
# Locally keep as 'development' to prevent seed script guards from firing
NODE_ENV=development
