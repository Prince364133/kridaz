generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider = "postgresql"
}

model User {
  id                      String                @id @default(uuid())
  email                   String                @unique
  username                String                @unique
  password                String
  role                    Role                  @default(USER)
  name                    String
  phone                   String?
  profilePicture          String?
  city                    String?
  state                   String?
  latitude                Decimal?              @db.Decimal(10, 8)
  longitude               Decimal?              @db.Decimal(11, 8)
  isVerified              Boolean               @default(false)
  isOnboarded             Boolean               @default(false)
  gender                  String?
  dob                     DateTime?
  bio                     String?
  interests               String[]
  sportTypes              String[]
  googleId                String?
  lastSeen                DateTime              @default(now())
  status                  String                @default("active")
  migrationStatus         Json?
  youtubeAccessToken      String?
  youtubeRefreshToken     String?
  youtubeTokenExpiry      DateTime?
  youtubeChannelId        String?
  youtubeChannelName      String?
  youtubeChannelThumb     String?
  facebookAccessToken     String?
  facebookPageId          String?
  facebookPageName        String?
  facebookPageThumb       String?
  socialAccounts          Json?
  notificationPreferences Json?
  walletBalance           Decimal               @default(0) @db.Decimal(12, 2)
  reservedBalance         Decimal               @default(0) @db.Decimal(12, 2)
  bookingCount            Int                   @default(0)
  createdAt               DateTime              @default(now())
  updatedAt               DateTime              @default(now()) @updatedAt
  auditLogs               AuditLog[]
  blogs                   Blog[]
  bookings                Booking[]
  createdChats            Chat[]                @relation("ChatCreatorUser")
  chatMemberships         ChatParticipant[]     @relation("UserChatMemberships")
  comments                Comment[]
  disputes                Dispute[]             @relation("DisputeRaiser")
  gameSlots               GameSlot[]
  hostedGames             HostedGame[]          @relation("HostRelation")
  scoredGames             HostedGame[]          @relation("ScorerRelation")
  streamedGames           HostedGame[]          @relation("StreamerRelation")
  officiatedGames         HostedGame[]          @relation("UmpireRelation")
  sentMessages            Message[]             @relation("MessageSenderUser")
  notifications           Notification[]
  otp                     OTP?
  ownerProfile            OwnerProfile?
  ownerRequests           OwnerRequest[]
  posts                   Post[]
  professionalBookings    ProfessionalBooking[]
  recoveryToken           RecoveryToken?
  reels                   Reel[]
  reelComments            ReelComment[]
  reelInteractions        ReelInteraction[]
  refreshTokens           RefreshToken[]
  reviews                 Review[]
  stories                 Story[]
  supportTickets          SupportTicket[]
  systemSettings          SystemSetting[]
  ownedTeams              Team[]                @relation("TeamOwner")
  teamMemberships         TeamMember[]
  oauth                   UserOAuth?
  profile                 UserProfile?
  followers               UserRelationship[]    @relation("Following")
  following               UserRelationship[]    @relation("Follower")
  stats                   UserStats?
  wallet                  Wallet?
  walletTransactions      WalletTransaction[]
  likedPosts              Post[]                @relation("PostLikes")
  studentSessions         ProfessionalSession[] @relation("SessionStudents")
  viewedStories           Story[]               @relation("StoryViewers")
  turfLikes               TurfLike[]
  turfInteractions        TurfInteraction[]
  professionalCustomers   ProfessionalCustomer[]
  careerStats             PlayerCareerStats[]
  earnedBadges            UserBadge[]

  @@index([role])
}

model UserProfile {
  id         String   @id @default(uuid())
  userId     String   @unique
  bio        String?
  gender     String?
  dob        DateTime?
  interests  String[] @default([])
  sportTypes String[] @default([])
  city       String?
  state      String?
  latitude   Decimal? @db.Decimal(10, 8)
  longitude  Decimal? @db.Decimal(11, 8)
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserOAuth {
  id                  String    @id @default(uuid())
  userId              String    @unique
  youtubeAccessToken  String?
  youtubeRefreshToken String?
  youtubeTokenExpiry  DateTime?
  youtubeChannelId    String?
  youtubeChannelName  String?
  youtubeChannelThumb String?
  facebookAccessToken String?
  facebookPageId      String?
  facebookPageName    String?
  facebookPageThumb   String?
  socialAccounts      Json?     @default("{}")
  updatedAt           DateTime  @updatedAt
  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model OTP {
  id        String   @id @default(uuid())
  email     String?  @unique
  phone     String?  @unique
  userId    String?  @unique
  emailOtp  String?
  phoneOtp  String?
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User?    @relation(fields: [userId], references: [id])
}

model RecoveryToken {
  id        String    @id @default(uuid())
  userId    String    @unique
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model OwnerRequest {
  id              String   @id @default(uuid())
  userId          String?
  name            String
  email           String   @unique
  phone           String
  status          String   @default("pending")
  role            String   @default("venue_owner")
  businessDetails Json?
  documents       Json?
  portfolioUrl    String?
  rejectionReason String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User?    @relation(fields: [userId], references: [id])

  @@index([userId])
}

model OwnerProfile {
  id                  String                     @id @default(uuid())
  userId              String                     @unique
  businessName        String
  verified            Boolean                    @default(false)
  walletBalance       Decimal                    @default(0) @db.Decimal(12, 2)
  reservedBalance     Decimal                    @default(0) @db.Decimal(12, 2)
  pendingBalance      Decimal                    @default(0) @db.Decimal(12, 2)
  inProgressBalance   Decimal                    @default(0) @db.Decimal(12, 2)
  disputeBalance      Decimal                    @default(0) @db.Decimal(12, 2)
  withdrawnBalance    Decimal                    @default(0) @db.Decimal(12, 2)
  price               Float                      @default(0)
  dob                 DateTime?
  gender              String?
  bio                 String?
  coachingLevel       String?
  availabilityTimings String?
  availabilityMode    String?
  preferredLocations  String?
  trainingTypes       String[]
  ageGroups           String[]
  languages           String?
  achievements        String?
  experience          String?
  specialization      String?
  certifications      String[]
  rating              Float                      @default(0)
  numReviews          Int                        @default(0)
  businessDetails     Json?
  bankingDetails      Json?
  verificationDocs    Json?
  notificationPrefs   Json?
  createdAt           DateTime                   @default(now())
  updatedAt           DateTime                   @updatedAt
  workingHours        Json?
  createdChats        Chat[]                     @relation("ChatCreatorOwner")
  chatMemberships     ChatParticipant[]          @relation("OwnerChatMemberships")
  coupons             Coupon[]
  disputes            Dispute[]
  sentMessages        Message[]                  @relation("MessageSenderOwner")
  notifications       Notification[]
  user                User                       @relation(fields: [userId], references: [id])
  availabilities      ProfessionalAvailability[]
  profBookings        ProfessionalBooking[]
  sessions            ProfessionalSession[]
  reviews             Review[]                   @relation("ProfessionalReview")
  turfs               Turf[]
  withdrawalRequests  WithdrawalRequest[]
  customers           ProfessionalCustomer[]
  tasks               ProfessionalTask[]
}

model WithdrawalRequest {
  id              String       @id @default(uuid())
  ownerId         String
  amount          Decimal      @db.Decimal(12, 2)
  status          String       @default("PENDING")
  bankDetails     Json
  transactionId   String?
  rejectionReason String?
  processedAt     DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  owner           OwnerProfile @relation(fields: [ownerId], references: [id])

  @@index([ownerId, createdAt])
}

model Turf {
  id                  String       @id @default(uuid())
  ownerId             String
  name                String
  description         String?
  location            String
  city                String
  state               String
  latitude            Decimal?     @db.Decimal(10, 8)
  longitude           Decimal?     @db.Decimal(11, 8)
  image               String
  images              String[]
  sportTypes          String[]
  groundTypes         String[]
  facilities          String[]
  youtubeUrl          String?
  pricePerHour        Decimal      @db.Decimal(10, 2)
  openTime            String
  closeTime           String
  isActive            Boolean      @default(true)
  status              String       @default("pending")
  slotDuration        Int          @default(60)
  breakTime           Int          @default(0)
  availableDays       String[]
  offDays             String[]
  slotsConfigDuration String       @default("Until Changed")
  slotsConfigWeeks    Int?
  slotsConfigExpiry   DateTime?
  slotsNeedsUpdate    Boolean      @default(false)
  slug                String?      @unique
  mapUrl              String?
  policies            String?      @default("")
  managerContacts     Json?
  generatedSlots      Json?
  verificationData    Json?
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @default(now()) @updatedAt
  bookings            Booking[]
  coupons             Coupon[]
  hostedGames         HostedGame[]
  reviews             Review[]
  timeSlots           TimeSlot[]
  turfLikes           TurfLike[]
  turfInteractions    TurfInteraction[]
  owner               OwnerProfile @relation(fields: [ownerId], references: [id])

  @@index([ownerId])
  @@index([city, state, status, isActive])
  @@index([slug])
}

model TimeSlot {
  id        String   @id @default(uuid())
  turfId    String
  startTime DateTime
  endTime   DateTime
  price     Decimal? @db.Decimal(10, 2)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  booking   Booking?
  turf      Turf     @relation(fields: [turfId], references: [id])

  @@index([turfId, startTime, endTime])
}

model Booking {
  id                 String              @id @default(uuid())
  userId             String
  turfId             String
  timeSlotId         String?             @unique
  totalPrice         Decimal             @db.Decimal(10, 2)
  paidAmount         Decimal             @db.Decimal(10, 2)
  balanceAmount      Decimal             @db.Decimal(10, 2)
  advanceAmount      Decimal             @default(0) @db.Decimal(10, 2)
  platformFee        Decimal             @default(0) @db.Decimal(10, 2)
  gstAmount          Decimal             @default(0) @db.Decimal(10, 2)
  ownerRevenue       Decimal             @default(0) @db.Decimal(10, 2)
  status             BookingStatus       @default(PENDING)
  revenueStatus      RevenueStatus       @default(PENDING)
  bookingSource      String              @default("USER")
  paymentMethod      String?
  paymentType        String              @default("FULL")
  qrCode             String?
  orderId            String?
  paymentId          String?
  paymentSignature   String?
  paymentStatus      String?             @default("PENDING")
  playStartTime      DateTime?
  playEndTime        DateTime?
  reviewWindowEndsAt DateTime?
  settledAt          DateTime?
  guestName          String?
  guestPhone         String?
  guestEmail         String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @default(now()) @updatedAt
  timeSlot           TimeSlot?           @relation(fields: [timeSlotId], references: [id])
  turf               Turf                @relation(fields: [turfId], references: [id])
  user               User                @relation(fields: [userId], references: [id])
  disputes           Dispute[]
  walletTransactions WalletTransaction[]

  @@index([userId, status])
  @@index([status, playStartTime])
  @@index([turfId, status, playStartTime])
  @@index([orderId])
}

model Wallet {
  id              String              @id @default(uuid())
  userId          String              @unique
  balance         Decimal             @default(0) @db.Decimal(12, 2)
  reservedBalance Decimal             @default(0) @db.Decimal(12, 2)
  user            User                @relation(fields: [userId], references: [id])
  transactions    WalletTransaction[]
}

model WalletTransaction {
  id                String   @id @default(uuid())
  userId            String
  amount            Decimal  @db.Decimal(12, 2)
  type              String
  status            String   @default("PENDING")
  description       String?
  razorpayOrderId   String?
  razorpayPaymentId String?
  bookingId         String?
  disputeId         String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  walletId          String?
  booking           Booking? @relation(fields: [bookingId], references: [id])
  user              User     @relation(fields: [userId], references: [id])
  wallet            Wallet?  @relation(fields: [walletId], references: [id])

  @@index([userId, createdAt])
  @@index([razorpayOrderId])
}

model Review {
  id             String        @id @default(uuid())
  userId         String
  turfId         String?
  professionalId String?
  rating         Int
  comment        String
  reply          String?
  replyDate      DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  professional   OwnerProfile? @relation("ProfessionalReview", fields: [professionalId], references: [id])
  turf           Turf?         @relation(fields: [turfId], references: [id])
  user           User          @relation(fields: [userId], references: [id])
}

model HostedGame {
  id                String               @id @default(uuid())
  hostId            String
  gameType          String
  gameMode          String               @default("PROFESSIONAL")
  date              DateTime
  time              String
  turfId            String?
  umpireId          String?
  scorerId          String?
  streamerId        String?
  umpireRequest     Json?
  scorerRequest     Json?
  streamerRequest   Json?
  streamConfig      Json?
  perPlayerCharge   Decimal              @default(0) @db.Decimal(10, 2)
  perSeatCharge     Decimal              @default(0) @db.Decimal(10, 2)
  groundCost        Decimal              @default(0) @db.Decimal(10, 2)
  umpireCost        Decimal              @default(0) @db.Decimal(10, 2)
  streamerCost      Decimal              @default(0) @db.Decimal(10, 2)
  totalCost         Decimal              @default(0) @db.Decimal(10, 2)
  status            String               @default("ACTIVE")
  shortId           String?              @unique
  scoringStatus     String               @default("NOT_STARTED")
  city              String?
  state             String?
  customVenue       String?
  isLive            Boolean              @default(false)
  streamStatus      String               @default("offline")
  overlayConfig     Json?
  liveStartedAt     DateTime?
  overlayToken      String?
  lastCommentary    String?
  lastCommentaryAt  DateTime?
  liveScoreSnapshot Json?
  oversPerInnings   Int                  @default(20)
  tickerTheme       String               @default("neon_classic")
  customUmpire      Json?
  customScorer      Json?
  customStreamer    Json?
  customProfessionals Json?
  
  // AI Commentary Settings
  isAiCommentaryEnabled Boolean @default(false)
  commentaryVoice       String  @default("en_US-lessac-medium") // Piper TTS voice model name
  commentaryLanguage    String  @default("en")
  commentaryStyle       String  @default("professional")

  // New fields for Scoring Match
  name              String?
  format            String?
  ballType          String?
  groundType        String?
  scoringPassword   String?
  youtubeLiveUrl    String?
  maxMembers        Int                  @default(11)
  
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  broadcasts        Broadcast[]
  cricketMatch      CricketMatch?
  invites           CustomPlayerInvite[]
  slots             GameSlot[]
  teams             GameTeam[]
  host              User                 @relation("HostRelation", fields: [hostId], references: [id])
  scorer            User?                @relation("ScorerRelation", fields: [scorerId], references: [id])
  streamer          User?                @relation("StreamerRelation", fields: [streamerId], references: [id])
  turf              Turf?                @relation(fields: [turfId], references: [id])
  umpire            User?                @relation("UmpireRelation", fields: [umpireId], references: [id])
}

model GameTeam {
  id        String     @id @default(uuid())
  gameId    String
  name      String
  image     String?
  teamKey   String
  createdAt DateTime   @default(now())
  slots     GameSlot[]
  game      HostedGame @relation(fields: [gameId], references: [id], onDelete: Cascade)
}

model GameSlot {
  id             String              @id @default(uuid())
  gameId         String
  teamId         String?
  userId         String?
  customPlayerId String?             @unique
  role           String?
  status         String              @default("OPEN")
  addedById      String?
  createdAt      DateTime            @default(now())
  customPlayer   CustomPlayerInvite? @relation("SlotInvite", fields: [customPlayerId], references: [id])
  game           HostedGame          @relation(fields: [gameId], references: [id], onDelete: Cascade)
  team           GameTeam?           @relation(fields: [teamId], references: [id])
  user           User?               @relation(fields: [userId], references: [id])
}

model CustomPlayerInvite {
  id           String     @id @default(uuid())
  gameId       String
  name         String
  email        String
  phone        String?
  userId       String?
  role         String     @default("PLAYER")
  isProfessional Boolean  @default(false)
  inviteToken  String?    @unique
  inviteStatus String     @default("PENDING")
  mustPay      Boolean    @default(false)
  invitedAt    DateTime   @default(now())
  createdAt    DateTime   @default(now())
  game         HostedGame @relation(fields: [gameId], references: [id], onDelete: Cascade)
  slot         GameSlot?  @relation("SlotInvite")
}

model CricketMatch {
  id                  String            @id @default(uuid())
  gameId              String            @unique
  status              String            @default("NOT_STARTED")
  timerState          String            @default("NOT_STARTED") // NOT_STARTED, RUNNING, PAUSED, ENDED
  timerLastStartedAt  DateTime?
  totalDurationSeconds Int              @default(0)
  result              String?
  tossWinner          String?
  tossDecision        String?
  currentInningsIndex Int               @default(0)
  oversPerInnings     Int               @default(20)
  strikerId           String?
  nonStrikerId        String?
  bowlerId            String?
  revisedTarget       Int?
  revisedOvers        Float?
  matchOfficials      Json?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  game                HostedGame        @relation(fields: [gameId], references: [id], onDelete: Cascade)
  innings             Innings[]
  timeline            MatchBall[]
  playerStats         MatchPlayerStat[]
}

model Innings {
  id           String       @id @default(uuid())
  matchId      String
  inningsIndex Int
  battingTeam  String
  totalRuns    Int          @default(0)
  totalWickets Int          @default(0)
  totalBalls         Int          @default(0)
  isCompleted        Boolean      @default(false)
  extras             Json
  battingTeamReviews Int          @default(2)
  fieldingTeamReviews Int         @default(2)
  powerplayOvers     Int          @default(0)
  createdAt          DateTime     @default(now())
  match        CricketMatch @relation(fields: [matchId], references: [id], onDelete: Cascade)
}

model MatchBall {
  id           String       @id @default(uuid())
  matchId      String
  inningsIndex Int
  over         Int
  ballInOver   Int
  batterId     String
  bowlerId     String
  fielderId    String?
  runs         Int          @default(0)
  isExtra      Boolean      @default(false)
  extraType    String       @default("NONE")
  extraRuns    Int          @default(0)
  isBoundary   Boolean      @default(false)
  isFour       Boolean      @default(false)
  isSix        Boolean      @default(false)
  isWicket     Boolean      @default(false)
  wicketType   String?
  playerOutId  String?
  wicketTakerId String?
  fieldingPosition String?
  distance     String?
  commentary   String?
  timestamp    DateTime     @default(now())
  match        CricketMatch @relation(fields: [matchId], references: [id], onDelete: Cascade)
}

model MatchPlayerStat {
  id             String       @id @default(uuid())
  matchId        String
  userId         String
  inningsIndex   Int
  battingRuns    Int          @default(0)
  battingBalls   Int          @default(0)
  battingFours   Int          @default(0)
  battingSixes   Int          @default(0)
  outStatus      String       @default("NOT_OUT")
  dismissedById  String?
  caughtById     String?
  bowlingOvers   Float        @default(0)
  bowlingBalls   Int          @default(0)
  bowlingMaidens Int          @default(0)
  bowlingRuns    Int          @default(0)
  bowlingWickets Int          @default(0)
  bowlingWides   Int          @default(0)
  bowlingNoBalls Int          @default(0)
  isSubstitute   Boolean      @default(false)
  substituteForId String?
  timeSpentSeconds Int        @default(0)
  timerLastStartedAt DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  match          CricketMatch @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@unique([matchId, userId, inningsIndex])
}

model Broadcast {
  id          String     @id @default(uuid())
  gameId      String
  platform    String
  accountId   String?
  accountName String?
  broadcastId String?
  streamId    String?
  videoId     String?
  streamKey   String?
  rtmpUrl     String?
  watchUrl    String?
  status      String     @default("offline")
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  game        HostedGame @relation(fields: [gameId], references: [id], onDelete: Cascade)
}

model Team {
  id                       String                @id @default(uuid())
  name                     String
  description              String?
  teamCode                 String?               @unique
  image                    String?
  logo                     String?
  city                     String?
  visibility               String                @default("PUBLIC")
  sportType                String                @default("CRICKET")
  captainName              String?
  captainPhone             String?
  qrCode                   String?
  ownerId                  String
  latitude                 Decimal?              @db.Decimal(10, 8)
  longitude                Decimal?              @db.Decimal(11, 8)
  createdAt                DateTime              @default(now())
  updatedAt                DateTime              @updatedAt
  owner                    User                  @relation("TeamOwner", fields: [ownerId], references: [id])
  customMembers            TeamCustomMember[]
  members                  TeamMember[]
  opponentRequestsSent     TeamOpponentRequest[] @relation("RequestFrom")
  opponentRequestsReceived TeamOpponentRequest[] @relation("RequestTo")
  Team_A                   Team[]                @relation("TeamOpponents")
  Team_B                   Team[]                @relation("TeamOpponents")
}

model TeamMember {
  id        String   @id @default(uuid())
  teamId    String
  userId    String
  role      String   @default("PLAYER")
  status    String   @default("JOINED")
  createdAt DateTime @default(now())
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id])
}

model TeamCustomMember {
  id          String   @id @default(uuid())
  teamId      String
  name        String
  email       String?
  phone       String?
  inviteToken String?  @unique
  status      String   @default("PENDING")
  createdAt   DateTime @default(now())
  team        Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
}

model TeamOpponentRequest {
  id        String   @id @default(uuid())
  fromId    String
  toId      String
  status    String   @default("PENDING")
  createdAt DateTime @default(now())
  from      Team     @relation("RequestFrom", fields: [fromId], references: [id])
  to        Team     @relation("RequestTo", fields: [toId], references: [id])
}

model UserStats {
  id        String   @id @default(uuid())
  userId    String   @unique
  matches   Int      @default(0)
  runs      Int      @default(0)
  wickets   Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
  badges    Badge[]
  user      User     @relation(fields: [userId], references: [id])
}

model Badge {
  id       String    @id @default(uuid())
  statsId  String
  name     String
  category String
  icon     String?
  earnedAt DateTime  @default(now())
  stats    UserStats @relation(fields: [statsId], references: [id])
}

model Notification {
  id             String        @id @default(uuid())
  userId         String?
  ownerId        String?
  recipientModel String?
  title          String
  message        String
  type           String?
  link           String?
  isRead         Boolean       @default(false)
  metadata       Json?
  createdAt      DateTime      @default(now())
  owner          OwnerProfile? @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  user           User?         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([ownerId])
}

model Reel {
  id              String            @id @default(uuid())
  creatorId       String
  caption         String?
  hashtags        String[]
  rawVideoUrl     String?
  hlsUrl          String?
  thumbnailUrl    String?
  aspectRatio     Float             @default(0.5625)
  duration        Float?
  status          String            @default("pending")
  isPrivate       Boolean           @default(false)
  views           Int               @default(0)
  likes           Int               @default(0)
  shares          Int               @default(0)
  comments        Int               @default(0)
  completionCount Int               @default(0)
  avgWatchTime    Float             @default(0)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @default(now()) @updatedAt
  creator         User              @relation(fields: [creatorId], references: [id])
  reelComments    ReelComment[]
  interactions    ReelInteraction[]

  @@index([status, isPrivate, id])
  @@index([creatorId, status])
}

model ReelComment {
  id        String        @id @default(uuid())
  reelId    String
  userId    String
  text      String
  parentId  String?       @map("parentId")
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  parent    ReelComment?  @relation("ReelCommentReplies", fields: [parentId], references: [id])
  replies   ReelComment[] @relation("ReelCommentReplies")
  reel      Reel          @relation(fields: [reelId], references: [id], onDelete: Cascade)
  user      User          @relation(fields: [userId], references: [id])

  @@index([reelId])
  @@index([userId])
}

model ReelInteraction {
  id             String   @id @default(uuid())
  reelId         String
  userId         String
  type           String
  watchTime      Float?
  completionRate Float?
  totalWatches   Int      @default(1)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  reel           Reel     @relation(fields: [reelId], references: [id], onDelete: Cascade)
  user           User     @relation(fields: [userId], references: [id])

  @@unique([userId, reelId, type])
  @@index([reelId])
  @@index([userId])
}

model Post {
  id          String    @id @default(uuid())
  authorId    String    @map("creatorId")
  title       String?
  content     String?
  mediaType   String    @default("image")
  mediaUrls   String[]
  placeholder String?
  status      String    @default("ready")
  hashtags    String[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @default(now()) @updatedAt
  comments    Comment[]
  author      User      @relation(fields: [authorId], references: [id])
  likes       User[]    @relation("PostLikes")

  @@index([authorId])
  @@index([status])
}

model Comment {
  id        String   @id @default(uuid())
  postId    String
  userId    String
  text      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id])

  @@index([postId])
  @@index([userId])
}

model Story {
  id           String   @id @default(uuid())
  userId       String
  mediaUrl     String?
  hlsUrl       String?
  placeholder  String?
  rawMediaUrl  String?
  content      String?
  mediaType    String   @default("image")
  durationDays Int      @default(1)
  expiresAt    DateTime
  status       String   @default("ready")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @default(now()) @updatedAt
  user         User     @relation(fields: [userId], references: [id])
  viewers      User[]   @relation("StoryViewers")

  @@index([userId])
  @@index([expiresAt])
}

model UserRelationship {
  id        String   @id @default(uuid())
  userId    String
  targetId  String
  type      String   @default("FOLLOW")
  createdAt DateTime @default(now())
  target    User     @relation("Following", fields: [targetId], references: [id])
  user      User     @relation("Follower", fields: [userId], references: [id])

  @@unique([userId, targetId, type])
  @@index([userId])
  @@index([targetId])
}

model SystemSetting {
  id          String   @id @default(uuid())
  key         String   @unique
  value       Json
  description String?
  updatedBy   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User?    @relation(fields: [updatedBy], references: [id])
}

model Coupon {
  id            String       @id @default(uuid())
  code          String       @unique
  ownerId       String
  turfId        String?
  discountType  String
  discountValue Decimal      @db.Decimal(10, 2)
  validUntil    DateTime
  usageLimit    Int          @default(0)
  timesUsed     Int          @default(0)
  isActive      Boolean      @default(true)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  owner         OwnerProfile @relation(fields: [ownerId], references: [id])
  turf          Turf?        @relation(fields: [turfId], references: [id])
}

model FeatureFlag {
  id          String   @id @default(uuid())
  key         String   @unique
  enabled     Boolean  @default(false)
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AdBanner {
  id        String   @id @default(uuid())
  title     String
  imageUrl  String
  targetUrl String?
  type      String   @default("HOME")
  isActive  Boolean  @default(true)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Video {
  id         String   @id @default(uuid())
  title      String
  youtubeUrl String
  order      Int      @default(0)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  action    String
  module    String
  targetId  String?
  details   Json?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id])
}

model Blog {
  id            String   @id @default(uuid())
  authorId      String
  title         String
  slug          String   @unique
  content       String
  summary       String?
  featuredImage String?
  tags          String[]
  status        String   @default("DRAFT")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  author        User     @relation(fields: [authorId], references: [id])

  @@index([authorId])
}

model Chat {
  id                  String            @id @default(uuid())
  chatName            String?
  isGroupChat         Boolean           @default(false)
  isCommunity         Boolean           @default(false)
  description         String?
  groupImage          String?
  parentCommunityId   String?
  isAnnouncementGroup Boolean           @default(false)
  adminOnlyMessages   Boolean           @default(false)
  latestMessageId     String?           @unique
  createdByUserId     String?
  createdByOwnerId    String?
  createdByModel      String            @default("User")
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  createdByOwner      OwnerProfile?     @relation("ChatCreatorOwner", fields: [createdByOwnerId], references: [id])
  createdByUser       User?             @relation("ChatCreatorUser", fields: [createdByUserId], references: [id])
  latestMessage       Message?          @relation("LatestMessage", fields: [latestMessageId], references: [id])
  parentCommunity     Chat?             @relation("CommunityHierarchy", fields: [parentCommunityId], references: [id])
  subCommunities      Chat[]            @relation("CommunityHierarchy")
  participants        ChatParticipant[]
  messages            Message[]         @relation("ChatMessages")

  @@index([parentCommunityId])
}

model ChatParticipant {
  id              String        @id @default(uuid())
  chatId          String
  userId          String?
  ownerId         String?
  onModel         String        @default("User")
  isAdmin         Boolean       @default(false)
  isPending       Boolean       @default(false)
  pinnedAt        DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  chat            Chat          @relation(fields: [chatId], references: [id], onDelete: Cascade)
  owner           OwnerProfile? @relation("OwnerChatMemberships", fields: [ownerId], references: [id])
  user            User?         @relation("UserChatMemberships", fields: [userId], references: [id])
  deletedMessages Message[]     @relation("MessageDeletedBy")
  readMessages    Message[]     @relation("MessageReadBy")

  @@unique([chatId, userId, ownerId])
  @@index([chatId])
}

model Message {
  id            String            @id @default(uuid())
  chatId        String
  senderUserId  String?
  senderOwnerId String?
  senderModel   String            @default("User")
  content       String?
  media         Json?
  isStarred     Boolean           @default(false)
  isForwarded   Boolean           @default(false)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  latestInChat  Chat?             @relation("LatestMessage")
  chat          Chat              @relation("ChatMessages", fields: [chatId], references: [id], onDelete: Cascade)
  senderOwner   OwnerProfile?     @relation("MessageSenderOwner", fields: [senderOwnerId], references: [id])
  senderUser    User?             @relation("MessageSenderUser", fields: [senderUserId], references: [id])
  deletedBy     ChatParticipant[] @relation("MessageDeletedBy")
  readBy        ChatParticipant[] @relation("MessageReadBy")

  @@index([chatId, createdAt])
}

model SupportTicket {
  id          String        @id @default(uuid())
  userId      String
  subject     String
  description String
  category    String
  status      String        @default("OPEN")
  priority    String        @default("MEDIUM")
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  user        User          @relation(fields: [userId], references: [id])
  replies     TicketReply[]

  @@index([userId, status])
}

model TicketReply {
  id         String        @id @default(uuid())
  ticketId   String
  senderType String
  senderId   String
  message    String
  images     String[]
  createdAt  DateTime      @default(now())
  ticket     SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
}

model Dispute {
  id             String         @id @default(uuid())
  bookingId      String
  raisedById     String
  ownerId        String?
  reason         String
  description    String
  images         String[]
  status         String         @default("PENDING")
  resolution     Json?
  bookingDetails Json?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  booking        Booking        @relation(fields: [bookingId], references: [id])
  owner          OwnerProfile?  @relation(fields: [ownerId], references: [id])
  raisedBy       User           @relation("DisputeRaiser", fields: [raisedById], references: [id])
  replies        DisputeReply[]

  @@index([status, createdAt])
}

model DisputeReply {
  id         String   @id @default(uuid())
  disputeId  String
  senderType String
  senderId   String
  message    String
  images     String[]
  createdAt  DateTime @default(now())
  dispute    Dispute  @relation(fields: [disputeId], references: [id], onDelete: Cascade)
}

model RefreshToken {
  id              String    @id @default(uuid())
  userId          String
  tokenHash       String    @unique
  expiresAt       DateTime
  createdByIp     String?
  revokedAt       DateTime?
  replacedByToken String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tokenHash])
}

model ProfessionalSession {
  id        String       @id @default(uuid())
  name      String
  type      String       @default("Group")
  date      DateTime
  time      String
  duration  String       @default("60 mins")
  coachId   String
  status    String       @default("upcoming")
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  coach     OwnerProfile @relation(fields: [coachId], references: [id])
  students  User[]       @relation("SessionStudents")
}

model ProfessionalAvailability {
  id             String       @id @default(uuid())
  professionalId String
  date           String
  slots          Json
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  professional   OwnerProfile @relation(fields: [professionalId], references: [id])

  @@unique([professionalId, date])
}

model ProfessionalBooking {
  id              String       @id @default(uuid())
  userId          String
  professionalId  String
  date            String
  slots           Json
  totalAmount     Float
  bookingType     String
  message         String?
  status          String       @default("PENDING")
  rejectionReason String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  professional    OwnerProfile @relation(fields: [professionalId], references: [id])
  user            User         @relation(fields: [userId], references: [id])
}

enum Role {
  USER
  VENUE_OWNER
  OWNER
  ADMIN
  UMPIRE
  LIMITED_UMPIRE
  COACH
  SCORER
  STREAMER
  SYSTEM
  ANONYMOUS
}

enum BookingStatus {
  PENDING
  CONFIRMED
  PLAYING
  IN_REVIEW_WINDOW
  COMPLETED
  DISPUTED
  CANCELLED
}

enum RevenueStatus {
  PENDING
  IN_PROGRESS
  SETTLED
  FROZEN
  REFUNDED
}

model TurfLike {
  id        String   @id @default(uuid())
  userId    String
  turfId    String
  createdAt DateTime @default(now())
  
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  turf      Turf     @relation(fields: [turfId], references: [id], onDelete: Cascade)

  @@unique([userId, turfId])
  @@index([userId])
  @@index([turfId])
}

model TurfInteraction {
  id              String   @id @default(uuid())
  userId          String?
  turfId          String
  interactionType String   // 'VIEW', 'SHARE', 'CLICK', 'SEARCH'
  duration        Int      @default(0) // Dwell time in seconds (for views)
  createdAt       DateTime @default(now())

  user            User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  turf            Turf     @relation(fields: [turfId], references: [id], onDelete: Cascade)

  @@index([userId, interactionType])
  @@index([turfId, interactionType])
  @@index([createdAt])
}

model ProfessionalCustomer {
  id              String       @id @default(uuid())
  professionalId  String
  userId          String?
  name            String
  email           String?
  phone           String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  professional    OwnerProfile @relation(fields: [professionalId], references: [id])
  user            User?        @relation(fields: [userId], references: [id])
  tasks           ProfessionalTask[]
}

model ProfessionalTask {
  id              String       @id @default(uuid())
  professionalId  String
  customerId      String?
  title           String
  description     String?
  date            DateTime
  startTime       String
  endTime         String
  reminderMinutes Int          @default(30)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  professional    OwnerProfile @relation(fields: [professionalId], references: [id])
  customer        ProfessionalCustomer? @relation(fields: [customerId], references: [id])
}

model UserBadge {
  id          String   @id @default(uuid())
  userId      String
  name        String
  description String
  sportType   String
  category    String
  badgeIcon   String
  earnedAt    DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId, sportType])
}

model PlayerCareerStats {
  id                 String   @id @default(uuid())
  userId             String
  sportType          String   @default("CRICKET")
  
  matchesPlayed      Int      @default(0)
  matchesWon         Int      @default(0)
  matchesLost        Int      @default(0)
  winPercentage      Float    @default(0.0)
  
  totalRuns          Int      @default(0)
  ballsFaced         Int      @default(0)
  fours              Int      @default(0)
  sixes              Int      @default(0)
  centuries          Int      @default(0)
  halfCenturies      Int      @default(0)
  highestScore       Int      @default(0)
  battingAverage     Float    @default(0.0)
  battingStrikeRate  Float    @default(0.0)
  
  ballsBowled        Int      @default(0)
  runsConceded       Int      @default(0)
  wickets            Int      @default(0)
  fiveWicketHauls    Int      @default(0)
  bestBowlingRuns    Int      @default(0)
  bestBowlingWickets  Int      @default(0)
  bowlingAverage     Float    @default(0.0)
  bowlingEconomy     Float    @default(0.0)

  updatedAt          DateTime @updatedAt
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, sportType])
  @@index([userId])
}

