// schema.prisma
generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  // extensions = [postgis] // Disabled: PostGIS not available on current DB
}

enum Role {
  USER
  VENUE_OWNER
  OWNER
  ADMIN
  UMPIRE
  LIMITED_UMPIRE
  COACH
  SCORER
  STREAMER
  SYSTEM
  ANONYMOUS
}

// ── 1. IDENTITY & PROFILES ──────────────────────────────────────────────────

model User {
  id             String  @id @default(uuid())
  email          String  @unique
  username       String  @unique
  password       String
  role           Role    @default(USER)
  name           String
  phone          String?
  profilePicture String?
  city           String?
  state          String?

  // Coordinates (Fallback for PostGIS)
  latitude  Decimal? @db.Decimal(10, 8)
  longitude Decimal? @db.Decimal(11, 8)

  // PostGIS location
  // PostGIS geography point (Point, 4326)
  // geoPoint Unsupported("geography(Point, 4326)")?

  isVerified Boolean @default(false)

  gender          String? // Male, Female, Other, Prefer not to say
  bio             String?
  interests       String[]
  sportTypes      String[]
  googleId        String?
  lastSeen        DateTime @default(now())
  status          String   @default("active") // active, blocked
  migrationStatus Json? // { social: boolean, stats: boolean, normalized: boolean }

  // Social Media & Streaming
  youtubeAccessToken      String?
  youtubeRefreshToken     String?
  youtubeTokenExpiry      DateTime?
  youtubeChannelId        String?
  youtubeChannelName      String?
  youtubeChannelThumb     String?
  facebookAccessToken     String?
  facebookPageId          String?
  facebookPageName        String?
  facebookPageThumb       String?
  socialAccounts          Json? // Array of objects
  notificationPreferences Json? // { email, whatsapp, marketing, etc. }

  // Wallet (Legacy Parity)
  walletBalance   Decimal @default(0) @db.Decimal(12, 2)
  reservedBalance Decimal @default(0) @db.Decimal(12, 2)
  bookingCount    Int     @default(0)

  // Relations
  ownerProfile       OwnerProfile?
  wallet             Wallet?
  bookings           Booking[]
  reviews            Review[]
  hostedGames        HostedGame[]        @relation("HostRelation")
  officiatedGames    HostedGame[]        @relation("UmpireRelation")
  scoredGames        HostedGame[]        @relation("ScorerRelation")
  streamedGames      HostedGame[]        @relation("StreamerRelation")
  gameSlots          GameSlot[]
  ownedTeams         Team[]              @relation("TeamOwner")
  teamMemberships    TeamMember[]
  stats              UserStats?
  notifications      Notification[]
  reels              Reel[]
  reelInteractions   ReelInteraction[]
  reelComments       ReelComment[]
  posts              Post[]
  comments           Comment[]
  likedPosts         Post[]              @relation("PostLikes")
  systemSettings     SystemSetting[]
  stories            Story[]
  viewedStories      Story[]             @relation("StoryViewers")
  following          UserRelationship[]  @relation("Follower")
  followers          UserRelationship[]  @relation("Following")
  walletTransactions WalletTransaction[]

  // New Relations
  profile         UserProfile?
  oauth           UserOAuth?
  otp             OTP?
  ownerRequests   OwnerRequest[]
  refreshTokens   RefreshToken[]
  studentSessions ProfessionalSession[] @relation("SessionStudents")
  chatMemberships ChatParticipant[]     @relation("UserChatMemberships")
  createdChats    Chat[]                @relation("ChatCreatorUser")
  sentMessages    Message[]             @relation("MessageSenderUser")
  supportTickets  SupportTicket[]
  disputes        Dispute[]             @relation("DisputeRaiser")
  auditLogs       AuditLog[]
  blogs           Blog[]
  recoveryToken   RecoveryToken?

  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @default(now()) @updatedAt
  professionalBookings ProfessionalBooking[]

  @@index([role])
}

model UserProfile {
  id         String   @id @default(uuid())
  userId     String   @unique
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  bio        String?  @db.Text
  gender     String?
  interests  String[] @default([])
  sportTypes String[] @default([])
  city       String?
  state      String?
  latitude   Decimal? @db.Decimal(10, 8)
  longitude  Decimal? @db.Decimal(11, 8)
  updatedAt  DateTime @updatedAt
}

model UserOAuth {
  id                  String    @id @default(uuid())
  userId              String    @unique
  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  youtubeAccessToken  String?
  youtubeRefreshToken String?
  youtubeTokenExpiry  DateTime?
  youtubeChannelId    String?
  youtubeChannelName  String?
  youtubeChannelThumb String?
  facebookAccessToken String?
  facebookPageId      String?
  facebookPageName    String?
  facebookPageThumb   String?
  socialAccounts      Json?     @default("{}")
  updatedAt           DateTime  @updatedAt
}

model OTP {
  id     String  @id @default(uuid())
  email  String? @unique
  phone  String? @unique
  userId String? @unique
  user   User?   @relation(fields: [userId], references: [id])

  emailOtp String?
  phoneOtp String?

  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model RecoveryToken {
  id        String    @id @default(uuid())
  userId    String    @unique
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
}

model OwnerRequest {
  id     String  @id @default(uuid())
  userId String?
  user   User?   @relation(fields: [userId], references: [id])

  name   String
  email  String @unique
  phone  String
  status String @default("pending") // pending, approved, rejected
  role   String @default("venue_owner") // venue_owner, owner, coach, umpire, streamer, scorer

  businessDetails Json?
  documents       Json?
  portfolioUrl    String?
  rejectionReason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model OwnerProfile {
  id     String @id @default(uuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id])

  businessName String
  verified     Boolean @default(false)

  // Balances
  walletBalance     Decimal @default(0) @db.Decimal(12, 2)
  reservedBalance   Decimal @default(0) @db.Decimal(12, 2)
  pendingBalance    Decimal @default(0) @db.Decimal(12, 2)
  inProgressBalance Decimal @default(0) @db.Decimal(12, 2)
  disputeBalance    Decimal @default(0) @db.Decimal(12, 2)
  withdrawnBalance  Decimal @default(0) @db.Decimal(12, 2)

  // Professional details
  price               Float     @default(0)
  dob                 DateTime?
  gender              String? // Male, Female, Other
  bio                 String?
  coachingLevel       String? // Beginner, Intermediate, Elite
  availabilityTimings String?
  availabilityMode    String? // Offline, Online, Both
  preferredLocations  String?
  trainingTypes       String[]
  ageGroups           String[]
  languages           String?
  achievements        String?
  experience          String?
  specialization      String?
  certifications      String[]

  rating     Float @default(0)
  numReviews Int   @default(0)

  // Complex fields (JSON for now)
  businessDetails   Json?
  bankingDetails    Json?
  verificationDocs  Json?
  notificationPrefs Json?

  turfs              Turf[]
  coupons            Coupon[]
  reviews            Review[]                   @relation("ProfessionalReview")
  withdrawalRequests WithdrawalRequest[]
  sessions           ProfessionalSession[]
  availabilities     ProfessionalAvailability[]
  profBookings       ProfessionalBooking[]

  notifications Notification[]

  // Chat Relations
  chatMemberships ChatParticipant[] @relation("OwnerChatMemberships")
  createdChats    Chat[]            @relation("ChatCreatorOwner")
  sentMessages    Message[]         @relation("MessageSenderOwner")

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  disputes  Dispute[]
}

model WithdrawalRequest {
  id      String       @id @default(uuid())
  ownerId String
  owner   OwnerProfile @relation(fields: [ownerId], references: [id])

  amount Decimal @db.Decimal(12, 2)
  status String  @default("PENDING") // PENDING, PROCESSING, COMPLETED, FAILED, REJECTED

  bankDetails     Json
  transactionId   String?
  rejectionReason String?
  processedAt     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ownerId, createdAt])
}

// ── 2. VENUE & SLOTS ────────────────────────────────────────────────────────

model Turf {
  id      String       @id @default(uuid())
  ownerId String
  owner   OwnerProfile @relation(fields: [ownerId], references: [id])

  name        String
  description String?
  location    String
  city        String
  state       String

  latitude  Decimal? @db.Decimal(10, 8)
  longitude Decimal? @db.Decimal(11, 8)

  // PostGIS location
  // PostGIS geography point (Point, 4326)
  // geoPoint Unsupported("geography(Point, 4326)")?

  image       String
  images      String[]
  sportTypes  String[]
  groundTypes String[]
  facilities  String[]
  youtubeUrl  String?

  pricePerHour Decimal @db.Decimal(10, 2)
  openTime     String
  closeTime    String

  isActive Boolean @default(true)
  status   String  @default("pending") // approved, pending, rejected

  slotDuration  Int      @default(60)
  breakTime     Int      @default(0)
  availableDays String[]
  offDays       String[]

  slotsConfigDuration String    @default("Until Changed")
  slotsConfigWeeks    Int?
  slotsConfigExpiry   DateTime?
  slotsNeedsUpdate    Boolean   @default(false)

  slug     String? @unique
  mapUrl   String?
  policies String? @default("")

  managerContacts  Json?
  verificationData Json?

  bookings    Booking[]
  timeSlots   TimeSlot[]
  coupons     Coupon[]
  reviews     Review[]
  hostedGames HostedGame[]

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@index([ownerId])
  @@index([city, state, status, isActive])
  @@index([slug])
}

model TimeSlot {
  id     String @id @default(uuid())
  turfId String
  turf   Turf   @relation(fields: [turfId], references: [id])

  startTime DateTime
  endTime   DateTime
  price     Decimal? @db.Decimal(10, 2)

  booking Booking?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([turfId, startTime, endTime])
}

// ── 3. BOOKING & WALLET ─────────────────────────────────────────────────────

enum BookingStatus {
  PENDING
  CONFIRMED
  PLAYING
  IN_REVIEW_WINDOW
  COMPLETED
  DISPUTED
  CANCELLED
}

enum RevenueStatus {
  PENDING
  IN_PROGRESS
  SETTLED
  FROZEN
  REFUNDED
}

model Booking {
  id         String    @id @default(uuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id])
  turfId     String
  turf       Turf      @relation(fields: [turfId], references: [id])
  timeSlotId String?   @unique
  timeSlot   TimeSlot? @relation(fields: [timeSlotId], references: [id])

  totalPrice    Decimal @db.Decimal(10, 2)
  paidAmount    Decimal @db.Decimal(10, 2)
  balanceAmount Decimal @db.Decimal(10, 2)
  advanceAmount Decimal @default(0) @db.Decimal(10, 2)
  platformFee   Decimal @default(0) @db.Decimal(10, 2)
  gstAmount     Decimal @default(0) @db.Decimal(10, 2)
  ownerRevenue  Decimal @default(0) @db.Decimal(10, 2)

  status        BookingStatus @default(PENDING)
  revenueStatus RevenueStatus @default(PENDING)
  bookingSource String        @default("USER") // USER, PARTNER_MANUAL
  paymentMethod String? // ONLINE, WALLET, CASH, UPI, etc.
  paymentType   String        @default("FULL") // PARTIAL, FULL

  qrCode           String?
  orderId          String?
  paymentId        String?
  paymentSignature String?
  paymentStatus    String? @default("PENDING") // PENDING, SUCCESS, FAILED

  playStartTime      DateTime?
  playEndTime        DateTime?
  reviewWindowEndsAt DateTime?
  settledAt          DateTime?

  guestName          String?
  guestPhone         String?
  guestEmail         String?
  walletTransactions WalletTransaction[]
  disputes           Dispute[]

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@index([userId, status])
  @@index([status, playStartTime])
  @@index([turfId, status, playStartTime])
  @@index([orderId])
}

model Wallet {
  id     String @id @default(uuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id])

  balance      Decimal             @default(0) @db.Decimal(12, 2)
  transactions WalletTransaction[]
}

model WalletTransaction {
  id String @id @default(uuid())

  // Link to either User or Wallet
  userId String
  user   User   @relation(fields: [userId], references: [id])

  amount      Decimal @db.Decimal(12, 2)
  type        String // TOPUP, DEBIT, REFUND, OFFER, etc.
  status      String  @default("PENDING") // PENDING, SUCCESS, FAILED, RESERVED
  description String?

  razorpayOrderId   String?
  razorpayPaymentId String?

  // References
  bookingId String?
  booking   Booking? @relation(fields: [bookingId], references: [id])

  disputeId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  wallet    Wallet?  @relation(fields: [walletId], references: [id])
  walletId  String?
  @@index([userId, createdAt])
  @@index([razorpayOrderId])
}

// ── 4. SOCIAL & GAMES ───────────────────────────────────────────────────────

model Review {
  id             String        @id @default(uuid())
  userId         String
  user           User          @relation(fields: [userId], references: [id])
  turfId         String?
  turf           Turf?         @relation(fields: [turfId], references: [id])
  professionalId String?
  professional   OwnerProfile? @relation("ProfessionalReview", fields: [professionalId], references: [id])

  rating    Int
  comment   String
  reply     String?
  replyDate DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model HostedGame {
  id       String   @id @default(uuid())
  hostId   String
  host     User     @relation("HostRelation", fields: [hostId], references: [id])
  gameType String
  gameMode String   @default("PROFESSIONAL") // QUICK, PROFESSIONAL
  date     DateTime
  time     String
  turfId   String?
  turf     Turf?    @relation(fields: [turfId], references: [id])

  umpireId   String?
  umpire     User?   @relation("UmpireRelation", fields: [umpireId], references: [id])
  scorerId   String?
  scorer     User?   @relation("ScorerRelation", fields: [scorerId], references: [id])
  streamerId String?
  streamer   User?   @relation("StreamerRelation", fields: [streamerId], references: [id])

  umpireRequest   Json?
  scorerRequest   Json?
  streamerRequest Json?
  streamConfig    Json?

  perPlayerCharge Decimal @default(0) @db.Decimal(10, 2)
  perSeatCharge   Decimal @default(0) @db.Decimal(10, 2)
  groundCost      Decimal @default(0) @db.Decimal(10, 2)
  umpireCost      Decimal @default(0) @db.Decimal(10, 2)
  streamerCost    Decimal @default(0) @db.Decimal(10, 2)
  totalCost       Decimal @default(0) @db.Decimal(10, 2)

  status        String  @default("ACTIVE") // PENDING, ACTIVE, COMPLETED, CANCELLED
  shortId       String? @unique
  scoringStatus String  @default("NOT_STARTED")

  city  String?
  state String?

  // Live Streaming & Overlay
  isLive            Boolean   @default(false)
  streamStatus      String    @default("offline")
  overlayConfig     Json?
  liveStartedAt     DateTime?
  overlayToken      String?
  lastCommentary    String?
  lastCommentaryAt  DateTime?
  liveScoreSnapshot Json?
  oversPerInnings   Int       @default(20)
  tickerTheme       String    @default("classic")

  // Off-platform Invites (Custom Roles)
  customUmpire   Json?
  customScorer   Json?
  customStreamer Json?

  // Normalized relations
  teams        GameTeam[]
  slots        GameSlot[]
  broadcasts   Broadcast[]
  invites      CustomPlayerInvite[]
  cricketMatch CricketMatch?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model GameTeam {
  id     String     @id @default(uuid())
  gameId String
  game   HostedGame @relation(fields: [gameId], references: [id], onDelete: Cascade)

  name    String
  image   String?
  teamKey String // teamA, teamB

  slots GameSlot[]

  createdAt DateTime @default(now())
}

model GameSlot {
  id     String     @id @default(uuid())
  gameId String
  game   HostedGame @relation(fields: [gameId], references: [id], onDelete: Cascade)

  teamId String?
  team   GameTeam? @relation(fields: [teamId], references: [id])

  userId String?
  user   User?   @relation(fields: [userId], references: [id])

  customPlayerId String?             @unique
  customPlayer   CustomPlayerInvite? @relation("SlotInvite", fields: [customPlayerId], references: [id])

  role      String?
  status    String  @default("OPEN") // OPEN, HELD, PENDING, JOINED
  addedById String?

  createdAt DateTime @default(now())
}

model CustomPlayerInvite {
  id     String     @id @default(uuid())
  gameId String
  game   HostedGame @relation(fields: [gameId], references: [id], onDelete: Cascade)

  name  String
  email String
  phone String?

  userId       String? // If they eventually sign up
  inviteToken  String? @unique
  inviteStatus String  @default("PENDING") // PENDING, ACCEPTED, EXPIRED
  mustPay      Boolean @default(false)

  slot GameSlot? @relation("SlotInvite")

  invitedAt DateTime @default(now())
  createdAt DateTime @default(now())
}

model CricketMatch {
  id     String     @id @default(uuid())
  gameId String     @unique
  game   HostedGame @relation(fields: [gameId], references: [id], onDelete: Cascade)

  status String  @default("LIVE") // LIVE, COMPLETED
  result String?

  tossWinner   String?
  tossDecision String? // BAT, BOWL

  currentInningsIndex Int @default(0)
  oversPerInnings     Int @default(20)

  // Active state
  strikerId    String?
  nonStrikerId String?
  bowlerId     String?

  innings     Innings[]
  timeline    MatchBall[]
  playerStats MatchPlayerStat[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Innings {
  id      String       @id @default(uuid())
  matchId String
  match   CricketMatch @relation(fields: [matchId], references: [id], onDelete: Cascade)

  inningsIndex Int
  battingTeam  String // teamA, teamB

  totalRuns    Int     @default(0)
  totalWickets Int     @default(0)
  totalBalls   Int     @default(0)
  isCompleted  Boolean @default(false)

  extras Json // {wides, noBalls, byes, legByes, penalty}

  createdAt DateTime @default(now())
}

model MatchBall {
  id      String       @id @default(uuid())
  matchId String
  match   CricketMatch @relation(fields: [matchId], references: [id], onDelete: Cascade)

  inningsIndex Int
  over         Int
  ballInOver   Int

  batterId  String
  bowlerId  String
  fielderId String?

  runs       Int     @default(0)
  isExtra    Boolean @default(false)
  extraType  String  @default("NONE") // WIDE, NO_BALL, etc.
  isBoundary Boolean @default(false)
  isWicket   Boolean @default(false)
  wicketType String?

  commentary String?
  timestamp  DateTime @default(now())
}

model MatchPlayerStat {
  id      String       @id @default(uuid())
  matchId String
  match   CricketMatch @relation(fields: [matchId], references: [id], onDelete: Cascade)

  userId       String
  inningsIndex Int

  // Batting
  battingRuns   Int     @default(0)
  battingBalls  Int     @default(0)
  battingFours  Int     @default(0)
  battingSixes  Int     @default(0)
  outStatus     String  @default("NOT_OUT")
  dismissedById String?
  caughtById    String?

  // Bowling
  bowlingOvers   Float @default(0)
  bowlingBalls   Int   @default(0)
  bowlingMaidens Int   @default(0)
  bowlingRuns    Int   @default(0)
  bowlingWickets Int   @default(0)
  bowlingWides   Int   @default(0)
  bowlingNoBalls Int   @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([matchId, userId, inningsIndex])
}

model Broadcast {
  id     String     @id @default(uuid())
  gameId String
  game   HostedGame @relation(fields: [gameId], references: [id], onDelete: Cascade)

  platform    String // youtube, facebook
  accountId   String?
  accountName String?
  broadcastId String? // YouTube broadcastId
  streamId    String? // YouTube streamId
  videoId     String? // YouTube videoId or Facebook videoId
  streamKey   String?
  rtmpUrl     String?
  watchUrl    String?
  status      String  @default("offline")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Team {
  id           String  @id @default(uuid())
  name         String
  description  String?
  teamCode     String? @unique
  image        String?
  logo         String? // Alias for image parity
  city         String?
  visibility   String  @default("PUBLIC") // PUBLIC, PRIVATE
  sportType    String  @default("CRICKET")
  captainName  String?
  captainPhone String?
  qrCode       String?

  ownerId String
  owner   User   @relation("TeamOwner", fields: [ownerId], references: [id])

  latitude  Decimal? @db.Decimal(10, 8)
  longitude Decimal? @db.Decimal(11, 8)

  // PostGIS location
  // PostGIS geography point (Point, 4326)
  // geoPoint Unsupported("geography(Point, 4326)")?

  members       TeamMember[]
  customMembers TeamCustomMember[]

  // Opponent relations
  opponents   Team[] @relation("TeamOpponents")
  opponentsOf Team[] @relation("TeamOpponents")

  opponentRequestsSent     TeamOpponentRequest[] @relation("RequestFrom")
  opponentRequestsReceived TeamOpponentRequest[] @relation("RequestTo")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TeamMember {
  id     String @id @default(uuid())
  teamId String
  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)
  userId String
  user   User   @relation(fields: [userId], references: [id])

  role   String @default("PLAYER") // CAPTAIN, PLAYER, VICE_CAPTAIN
  status String @default("JOINED") // PENDING, JOINED, REJECTED

  createdAt DateTime @default(now())
}

model TeamCustomMember {
  id     String @id @default(uuid())
  teamId String
  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)

  name        String
  email       String?
  phone       String?
  inviteToken String? @unique
  status      String  @default("PENDING") // PENDING, JOINED, EXPIRED

  createdAt DateTime @default(now())
}

model TeamOpponentRequest {
  id     String @id @default(uuid())
  fromId String
  from   Team   @relation("RequestFrom", fields: [fromId], references: [id])
  toId   String
  to     Team   @relation("RequestTo", fields: [toId], references: [id])

  status String @default("PENDING") // PENDING, ACCEPTED, REJECTED

  createdAt DateTime @default(now())
}

model UserStats {
  id     String @id @default(uuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id])

  matches Int @default(0)
  runs    Int @default(0)
  wickets Int @default(0)

  badges Badge[]

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
}

model Badge {
  id      String    @id @default(uuid())
  statsId String
  stats   UserStats @relation(fields: [statsId], references: [id])

  name     String
  category String
  icon     String?
  earnedAt DateTime @default(now())
}

model Notification {
  id      String        @id @default(uuid())
  userId  String?
  user    User?         @relation(fields: [userId], references: [id], onDelete: Cascade)
  ownerId String?
  owner   OwnerProfile? @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  recipientModel String? // "User" or "Owner"

  title    String
  message  String
  type     String? // BOOKING, PAYMENT, etc.
  link     String?
  isRead   Boolean @default(false)
  metadata Json? // For extra data parity with Mongoose

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([ownerId])
}

// ── 5. FEED & MEDIA ─────────────────────────────────────────────────────────

model Reel {
  id        String @id @default(uuid())
  creatorId String
  creator   User   @relation(fields: [creatorId], references: [id])

  caption      String?
  hashtags     String[]
  rawVideoUrl  String?
  hlsUrl       String?
  thumbnailUrl String?
  aspectRatio  Float    @default(0.5625)
  duration     Float?

  status    String  @default("pending") // pending, processing, ready, failed
  isPrivate Boolean @default(false)

  views           Int   @default(0)
  likes           Int   @default(0)
  shares          Int   @default(0)
  comments        Int   @default(0)
  completionCount Int   @default(0)
  avgWatchTime    Float @default(0)

  interactions ReelInteraction[]
  reelComments ReelComment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@index([status, isPrivate, id])
  @@index([creatorId, status])
}

model ReelComment {
  id     String @id @default(uuid())
  reelId String
  reel   Reel   @relation(fields: [reelId], references: [id], onDelete: Cascade)
  userId String
  user   User   @relation(fields: [userId], references: [id])

  text     String
  parentId String?       @map("parentId")
  parent   ReelComment?  @relation("ReelCommentReplies", fields: [parentId], references: [id])
  replies  ReelComment[] @relation("ReelCommentReplies")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([reelId])
  @@index([userId])
}

model ReelInteraction {
  id     String @id @default(uuid())
  reelId String
  reel   Reel   @relation(fields: [reelId], references: [id], onDelete: Cascade)
  userId String
  user   User   @relation(fields: [userId], references: [id])

  type           String // like, view, share, complete
  watchTime      Float?
  completionRate Float?
  totalWatches   Int    @default(1)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, reelId, type])
  @@index([reelId])
  @@index([userId])
}

model Post {
  id       String @id @default(uuid())
  authorId String @map("creatorId")
  author   User   @relation(fields: [authorId], references: [id])

  title       String?
  content     String?
  mediaType   String   @default("image") // image, video, text
  mediaUrls   String[]
  placeholder String?
  status      String   @default("ready") // pending, processing, ready, failed

  hashtags String[]

  likes    User[]    @relation("PostLikes")
  comments Comment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@index([authorId])
  @@index([status])
}

model Comment {
  id     String @id @default(uuid())
  postId String
  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId String
  user   User   @relation(fields: [userId], references: [id])

  text      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([postId])
  @@index([userId])
}

model Story {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id])

  mediaUrl    String?
  hlsUrl      String?
  placeholder String?
  rawMediaUrl String?
  content     String?
  mediaType   String  @default("image") // image, text, video

  durationDays Int      @default(1)
  expiresAt    DateTime
  status       String   @default("ready") // pending, ready, failed

  viewers User[] @relation("StoryViewers")

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@index([userId])
  @@index([expiresAt])
}

// ── 7. SOCIAL RELATIONSHIPS ─────────────────────────────────────────────────

model UserRelationship {
  id       String @id @default(uuid())
  userId   String
  user     User   @relation("Follower", fields: [userId], references: [id])
  targetId String
  target   User   @relation("Following", fields: [targetId], references: [id])
  type     String @default("FOLLOW") // FOLLOW, BLOCK

  createdAt DateTime @default(now())

  @@unique([userId, targetId, type])
  @@index([userId])
  @@index([targetId])
}

model SystemSetting {
  id          String  @id @default(uuid())
  key         String  @unique
  value       Json
  description String?
  updatedBy   String?
  user        User?   @relation(fields: [updatedBy], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Coupon {
  id      String       @id @default(uuid())
  code    String       @unique
  ownerId String
  owner   OwnerProfile @relation(fields: [ownerId], references: [id])
  turfId  String?
  turf    Turf?        @relation(fields: [turfId], references: [id])

  discountType  String // PERCENTAGE, FLAT
  discountValue Decimal  @db.Decimal(10, 2)
  validUntil    DateTime
  usageLimit    Int      @default(0)
  timesUsed     Int      @default(0)
  isActive      Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model FeatureFlag {
  id          String  @id @default(uuid())
  key         String  @unique
  enabled     Boolean @default(false)
  name        String
  description String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AdBanner {
  id       String  @id @default(uuid())
  title    String
  image    String
  link     String?
  type     String  @default("HOME") // HOME, TURF, SOCIAL
  isActive Boolean @default(true)
  priority Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AuditLog {
  id        String  @id @default(uuid())
  userId    String?
  user      User?   @relation(fields: [userId], references: [id])
  action    String
  module    String
  targetId  String?
  details   Json?
  ipAddress String?
  userAgent String?

  createdAt DateTime @default(now())
}

model Blog {
  id       String @id @default(uuid())
  authorId String
  author   User   @relation(fields: [authorId], references: [id])

  title         String
  slug          String   @unique
  content       String
  summary       String?
  featuredImage String?
  tags          String[]
  status        String   @default("DRAFT") // DRAFT, PUBLISHED

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([authorId])
}

// ── 8. COMMUNICATION & SUPPORT ──────────────────────────────────────────────

model Chat {
  id          String  @id @default(uuid())
  chatName    String?
  isGroupChat Boolean @default(false)
  isCommunity Boolean @default(false)
  description String?
  groupImage  String?

  parentCommunityId String?
  parentCommunity   Chat?   @relation("CommunityHierarchy", fields: [parentCommunityId], references: [id])
  subCommunities    Chat[]  @relation("CommunityHierarchy")

  isAnnouncementGroup Boolean @default(false)
  adminOnlyMessages   Boolean @default(false)

  latestMessageId String?  @unique
  latestMessage   Message? @relation("LatestMessage", fields: [latestMessageId], references: [id])

  participants ChatParticipant[]
  messages     Message[]         @relation("ChatMessages")

  // Polymorphic Creator
  createdByUserId  String?
  createdByUser    User?         @relation("ChatCreatorUser", fields: [createdByUserId], references: [id])
  createdByOwnerId String?
  createdByOwner   OwnerProfile? @relation("ChatCreatorOwner", fields: [createdByOwnerId], references: [id])
  createdByModel   String        @default("User")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@index([parentCommunityId])
}

model ChatParticipant {
  id     String @id @default(uuid())
  chatId String
  chat   Chat   @relation(fields: [chatId], references: [id], onDelete: Cascade)

  // Polymorphic Participant
  userId  String?
  user    User?         @relation("UserChatMemberships", fields: [userId], references: [id])
  ownerId String?
  owner   OwnerProfile? @relation("OwnerChatMemberships", fields: [ownerId], references: [id])
  onModel String        @default("User")

  isAdmin   Boolean   @default(false)
  isPending Boolean   @default(false)
  pinnedAt  DateTime?

  // For Message Read/Delete tracking
  readMessages    Message[] @relation("MessageReadBy")
  deletedMessages Message[] @relation("MessageDeletedBy")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([chatId, userId, ownerId])
  @@index([chatId])
}

model Message {
  id     String @id @default(uuid())
  chatId String
  chat   Chat   @relation("ChatMessages", fields: [chatId], references: [id], onDelete: Cascade)

  // Polymorphic Sender
  senderUserId  String?
  senderUser    User?         @relation("MessageSenderUser", fields: [senderUserId], references: [id])
  senderOwnerId String?
  senderOwner   OwnerProfile? @relation("MessageSenderOwner", fields: [senderOwnerId], references: [id])
  senderModel   String        @default("User")

  content String?
  media   Json? // [{url, type}]

  isStarred   Boolean @default(false)
  isForwarded Boolean @default(false)

  readBy    ChatParticipant[] @relation("MessageReadBy")
  deletedBy ChatParticipant[] @relation("MessageDeletedBy")

  latestInChat Chat? @relation("LatestMessage")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([chatId, createdAt])
}

model SupportTicket {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id])

  subject     String
  description String
  category    String
  status      String @default("OPEN") // OPEN, IN_PROGRESS, RESOLVED, CLOSED
  priority    String @default("MEDIUM") // LOW, MEDIUM, HIGH, URGENT

  replies TicketReply[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, status])
}

model TicketReply {
  id       String        @id @default(uuid())
  ticketId String
  ticket   SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  senderType String // ADMIN, USER
  senderId   String
  message    String
  images     String[]

  createdAt DateTime @default(now())
}

model Dispute {
  id        String  @id @default(uuid())
  bookingId String
  booking   Booking @relation(fields: [bookingId], references: [id])

  raisedById String
  raisedBy   User   @relation("DisputeRaiser", fields: [raisedById], references: [id])

  ownerId String?
  owner   OwnerProfile? @relation(fields: [ownerId], references: [id])

  reason      String // VENUE_CLOSED, OVERBOOKING, etc.
  description String
  images      String[]
  status      String   @default("PENDING") // PENDING, INVESTIGATING, RESOLVED, CLOSED

  resolution Json? // {action, partialAmount, adminNote, resolvedAt, resolvedBy}

  replies DisputeReply[]

  // Snapshot for history
  bookingDetails Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, createdAt])
}

model DisputeReply {
  id        String  @id @default(uuid())
  disputeId String
  dispute   Dispute @relation(fields: [disputeId], references: [id], onDelete: Cascade)

  senderType String // ADMIN, USER
  senderId   String
  message    String
  images     String[]

  createdAt DateTime @default(now())
}

model RefreshToken {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  tokenHash String   @unique
  expiresAt DateTime

  createdByIp     String?
  revokedAt       DateTime?
  replacedByToken String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tokenHash])
}

model ProfessionalSession {
  id       String   @id @default(uuid())
  name     String
  type     String   @default("Group") // Private, Group, Masterclass
  date     DateTime
  time     String
  duration String   @default("60 mins")

  coachId String
  coach   OwnerProfile @relation(fields: [coachId], references: [id])

  students User[] @relation("SessionStudents")

  status String @default("upcoming") // upcoming, completed, cancelled

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ProfessionalAvailability {
  id             String       @id @default(uuid())
  professionalId String
  professional   OwnerProfile @relation(fields: [professionalId], references: [id])

  date  String // YYYY-MM-DD
  slots Json // [{startTime, endTime, isAvailable, bookedBy, bookingId}]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([professionalId, date])
}

model ProfessionalBooking {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id])

  professionalId String
  professional   OwnerProfile @relation(fields: [professionalId], references: [id])

  date            String
  slots           Json // [{startTime, endTime}]
  totalAmount     Float
  bookingType     String
  message         String?
  status          String  @default("PENDING") // PENDING, ACCEPTED, REJECTED
  rejectionReason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
